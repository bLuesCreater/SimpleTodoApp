<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- 顶部渐变区域 -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="@drawable/bg_toolbar_gradient"
        android:gravity="bottom"
        android:paddingHorizontal="24dp"
        android:paddingBottom="24dp"
        app:contentInsetStart="0dp"
        app:contentInsetEnd="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_greeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="我的待办"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/tv_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="今天也要加油哦 ✨"
                android:textColor="#B3FFFFFF"
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

    </androidx.appcompat.widget.Toolbar>

    <!-- 待办列表 - 使用NestedScrollView包裹以适应底部 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_todo"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="-40dp"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="100dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"/>

    <!-- 空状态 -->
    <LinearLayout
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="visible"
        android:paddingHorizontal="40dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <ImageView
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:src="@drawable/ic_empty_state"
            android:contentDescription="@string/msg_no_todo"
            android:alpha="0.7"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/msg_no_todo"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="点击右下角的 + 按钮添加"
            android:textColor="@color/outline"
            android:textSize="13sp"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab_add"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:text="新建待办"
        android:textColor="@color/white"
        android:contentDescription="@string/btn_add"
        android:icon="@android:drawable/ic_input_add"
        app:iconTint="@color/white"
        app:backgroundTint="@color/primary"
        app:elevation="6dp"
        app:iconSize="20dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
